# KidBot Configuration
# Child Companion Robot Settings

# API Configuration
api:
  deepseek:
    # API key loaded from .env file (DEEPSEEK_API_KEY)
    base_url: "https://api.deepseek.com"
    model: "deepseek-chat"

# Paths
paths:
  raw_docs: "data/raw_docs"
  vector_store: "data/vector_store"

# Robot Personality
robot:
  name: "VV"
  personality: "A 6-year-old curious and friendly robot who loves to learn and play. Speaks in simple, cheerful sentences that children can understand. Always positive and encouraging."

# RAG Settings
rag:
  collection_name: "kidbot_knowledge"
  embedding_model: "all-MiniLM-L6-v2"
  chunk_size: 500
  chunk_overlap: 50
  batch_size: 100

# Audio Settings
audio:
  tts_voice: "en-US-AnaNeural"  # Child-friendly voice
  temp_audio_file: "temp_output.mp3"
  listen_timeout: 5
  phrase_timeout: 3

# Voice Security Settings
voice_security:
  enabled: true
  threshold: 0.25
  owner_embedding_path: "data/voice_prints/owner_embedding.npy"
  model_save_dir: "saved_models/spkrec"

# Qwen-Omni Realtime (Aliyun DashScope) — multimodal realtime vision + voice
qwen_omni:
  # API key: prefer the DASHSCOPE_API_KEY environment variable (overrides this).
  # Never commit a real key. config.yaml is gitignored; this .example is not.
  api_key: ""              # e.g. "sk-xxxx" (or set DASHSCOPE_API_KEY env var)
  model: "qwen3.5-omni-plus-realtime"
  voice: "Cherry"
  # Base realtime WebSocket URL. Do NOT append "?model=..." — the SDK adds the
  # model query parameter automatically (a pre-existing one would be stripped).
  ws_url: "wss://dashscope.aliyuncs.com/api-ws/v1/realtime"
  input_sample_rate: 16000   # browser microphone PCM16 uplink (Hz)
  output_sample_rate: 24000  # Qwen-Omni audio downlink (Hz)
  vision_fps: 1.5            # camera frame sampling rate (frames per second)
